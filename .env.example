# Backend
IPRL_CAE_APP_NAME="IPRL/CAE Hub"
IPRL_CAE_ENVIRONMENT=local
IPRL_CAE_API_PREFIX=/api/v1
IPRL_CAE_CORS_ORIGINS=http://localhost:3000
IPRL_CAE_CONFIG_FILE=./config/iprl-cae.config.toml

# Servicios independientes del servidor. No se usan contenedores.
IPRL_CAE_DATABASE_URL=postgresql+psycopg://iprl_cae:change-me@localhost:5432/iprl_cae
IPRL_CAE_REDIS_URL=redis://localhost:6379/0
IPRL_CAE_DOCUMENT_STORAGE_PATH=./storage/documents
IPRL_CAE_MAX_UPLOAD_BYTES=52428800

# Seguridad
IPRL_CAE_SECRET_KEY=change-this-in-production
IPRL_CAE_LOG_LEVEL=INFO
IPRL_CAE_PUBLIC_BASE_URL=http://localhost:8000
IPRL_CAE_FRONTEND_BASE_URL=http://localhost:3000

# Frontend local/demo. En produccion esto debe venir de sesion/autenticacion real.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_TENANT_ID=1
NEXT_PUBLIC_DEMO_USER_ID=1

# Google SSO / OIDC. Crear credenciales OAuth 2.0 en Google Cloud y guardar el secreto solo en el entorno del servidor.
IPRL_CAE_GOOGLE_OIDC_CLIENT_ID=
IPRL_CAE_GOOGLE_OIDC_CLIENT_SECRET=
IPRL_CAE_SSO__GOOGLE__ALLOWED_DOMAINS=[]

# Email. En desarrollo se usa consola; en produccion define SMTP real por entorno.
IPRL_CAE_MAIL__PROVIDER=console
IPRL_CAE_SMTP_HOST=
IPRL_CAE_SMTP_PORT=
IPRL_CAE_SMTP_USER=
IPRL_CAE_SMTP_PASSWORD=

# OCR
TESSERACT_CMD=
TESSDATA_PREFIX=
